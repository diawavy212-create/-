<view class="page">
  <view class="card">
    <view class="section-title">教师树洞</view>
    <view class="mode-row">
      <view
        wx:for="{{anonymousOptions}}"
        wx:key="value"
        class="mode {{anonymousType == item.value ? 'active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectAnonymous"
      >{{item.label}}</view>
    </view>

    <input class="title-input" value="{{title}}" placeholder="请输入诉求标题" bindinput="onTitleInput" />
    <textarea class="textarea" value="{{content}}" placeholder="请填写具体诉求内容、问题描述或期望处理方式" bindinput="onInput" />

    <view class="form-row">
      <picker class="picker-chip" mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view>类目：{{categoryOptions[categoryIndex]}}</view>
      </picker>
      <picker class="picker-chip" mode="selector" range="{{emergencyOptions}}" range-key="label" value="{{emergencyIndex}}" bindchange="onEmergencyChange">
        <view>紧急：{{emergencyOptions[emergencyIndex].label}}</view>
      </picker>
    </view>

    <view class="attachment-row">
      <button class="attachment-button" bindtap="chooseAttachment">{{attachmentUrl ? "更换附件图片" : "上传附件图片"}}</button>
      <image wx:if="{{attachmentPreviewUrl}}" class="attachment-thumb" src="{{attachmentPreviewUrl}}" mode="aspectFill" bindtap="previewAttachment"></image>
    </view>

    <button class="primary-button" bindtap="submit">提交诉求</button>
  </view>

  <view class="card">
    <view class="section-title">办理进度</view>
    <block wx:if="{{items.length}}">
      <block wx:for="{{items}}" wx:for-item="appeal" wx:for-index="appealIndex" wx:key="id">
        <view class="appeal pressable" data-index="{{appealIndex}}" bindtap="openDetail">
          <view class="appeal-head">
            <view class="appeal-title">{{appeal.displayTitle}}</view>
          </view>
          <view class="appeal-meta">
            <text>{{appeal.anonymousText}}</text>
            <text>{{appeal.category}}</text>
            <text>{{appeal.emergencyText}}</text>
          </view>
          <view class="status-line">
            <view class="muted">状态：{{appeal.statusText}}</view>
            <view
              wx:if="{{appeal.canEvaluate}}"
              class="evaluate-arrow"
              data-id="{{appeal.id}}"
              catchtap="openSatisfactionById"
            >去评价 ›</view>
          </view>
          <view wx:if="{{appeal.handleContent}}" class="feedback-preview">反馈：{{appeal.handleContent}}</view>
          <view wx:if="{{appeal.hasSatisfaction}}" class="satisfaction-result">满意度：{{appeal.satisfactionText}}</view>
          <view wx:if="{{appeal.attachmentPreviewUrl}}" class="muted">附件：点击查看详情后预览</view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">暂无诉求记录</view>
  </view>

  <view wx:if="{{detailVisible}}" class="detail-mask" bindtap="closeDetail">
    <view class="detail-panel" catchtap="noop">
      <view class="detail-header">
        <view class="detail-title">{{currentDetail.displayTitle}}</view>
        <view class="detail-close" bindtap="closeDetail">×</view>
      </view>
      <scroll-view class="detail-scroll" scroll-y>
        <view class="detail-section">
          <view class="detail-label">内容</view>
          <view class="detail-content">{{currentDetail.content || "-"}}</view>
        </view>
        <view class="detail-grid">
          <view class="detail-item">
            <text>类目</text>
            <view>{{currentDetail.category || "-"}}</view>
          </view>
          <view class="detail-item">
            <text>紧急程度</text>
            <view>{{currentDetail.emergencyText || "-"}}</view>
          </view>
          <view class="detail-item">
            <text>实名/匿名</text>
            <view>{{currentDetail.anonymousText || "-"}}</view>
          </view>
          <view class="detail-item">
            <text>状态</text>
            <view>{{currentDetail.statusText || "-"}}</view>
          </view>
        </view>
        <view class="detail-section">
          <view class="detail-label">反馈</view>
          <view class="detail-content">{{currentDetail.handleContent || "暂无"}}</view>
        </view>
        <view wx:if="{{currentDetail.attachmentPreviewUrl}}" class="detail-section">
          <view class="detail-label">附件</view>
          <image class="detail-image" src="{{currentDetail.attachmentPreviewUrl}}" mode="aspectFill" bindtap="previewDetailAttachment"></image>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{satisfactionVisible}}" class="detail-mask" bindtap="closeSatisfaction">
    <view class="satisfaction-panel" catchtap="noop">
      <view class="detail-header">
        <view class="detail-title">满意度评价（教师）</view>
        <view class="detail-close" bindtap="closeSatisfaction">×</view>
      </view>
      <view class="satisfaction-body">
        <view class="satisfaction-target">{{evaluatingItem.displayTitle}}</view>
        <view class="muted">请选择本次树洞诉求办理结果的满意程度</view>
        <radio-group class="satisfaction-options" bindchange="selectSatisfaction">
          <label class="satisfaction-option" wx:for="{{satisfactionOptions}}" wx:key="value">
            <radio value="{{item.value}}" checked="{{satisfactionValue == item.value}}" color="#c51624" />
            <text>{{item.label}}</text>
          </label>
        </radio-group>
        <view class="satisfaction-actions">
          <button class="outline-button" bindtap="closeSatisfaction">取消</button>
          <button class="primary-button" loading="{{evaluating}}" bindtap="submitSatisfaction">提交评价</button>
        </view>
      </view>
    </view>
  </view>
</view>
