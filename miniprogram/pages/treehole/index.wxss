.mode-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mode {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: #667789;
  background: #ffffff;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.mode.active {
  color: #ffffff;
  background: linear-gradient(135deg, #c51624, #df4650);
}

.title-input {
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  color: #09213a;
  background: #ffffff;
  border: 1rpx solid #dde1e6;
  border-radius: 16rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #09213a;
  background: #ffffff;
  border: 1rpx solid #dde1e6;
  border-radius: 16rpx;
}

.form-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
}

.picker-chip {
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  color: #c51624;
  background: #f9e6e8;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.attachment-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.attachment-button {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0;
  margin: 0;
  color: #c51624;
  background: #ffffff;
  border: 1rpx solid #c51624;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.attachment-button::after {
  border: 0;
}

.attachment-thumb {
  width: 86rpx;
  height: 86rpx;
  border-radius: 12rpx;
}

.appeal {
  padding: 22rpx 0;
  border-top: 1rpx solid #dde1e6;
}

.appeal:first-of-type {
  border-top: 0;
}

.appeal-title {
  margin-bottom: 10rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.appeal-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.appeal-meta text {
  padding: 4rpx 14rpx;
  color: #c51624;
  background: #f9e6e8;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag {
  margin-top: 12rpx;
}

.feedback-preview {
  margin-top: 8rpx;
  color: #697789;
  font-size: 24rpx;
  line-height: 36rpx;
}

.detail-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.detail-panel {
  width: 100%;
  max-height: 78vh;
  overflow: hidden;
  background: #ffffff;
  border-radius: 20rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 30rpx 34rpx 20rpx;
  border-bottom: 1rpx solid #edf0f4;
}

.detail-title {
  flex: 1;
  color: #09213a;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
  word-break: break-all;
}

.detail-close {
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  color: #94a3b8;
  font-size: 42rpx;
}

.detail-scroll {
  max-height: 62vh;
  padding: 26rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-label {
  margin-bottom: 10rpx;
  color: #667789;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-content {
  color: #213247;
  font-size: 28rpx;
  line-height: 44rpx;
  word-break: break-all;
  white-space: pre-wrap;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-item {
  padding: 18rpx;
  background: #f7f8fa;
  border-radius: 14rpx;
}

.detail-item text {
  display: block;
  margin-bottom: 8rpx;
  color: #8090a2;
  font-size: 22rpx;
}

.detail-item view {
  color: #213247;
  font-size: 26rpx;
  word-break: break-all;
}

.detail-image {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
}
