<view class="page">
  <view class="top-red">
    <view class="nav-title">西电教师服务</view>
  </view>

  <view class="user-row card">
    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" bindtap="chooseAvatarFallback">
      <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="logo-ring">XDU</view>
    </button>
    <view class="user-copy">
      <view class="hello">{{greeting}}，{{teacherTitle}}</view>
      <view class="muted">西安电子科技大学 · 教师 · 个人服务</view>
    </view>
  </view>

  <view class="hero pressable">
    <view>
      <view class="hero-kicker">教师综合服务平台</view>
      <view class="hero-title">教师服务</view>
      <view class="hero-sub">个人信息管理 | 教师树洞 | 思政培训活动</view>
    </view>
    <view class="hero-chart">
      <view class="bar short"></view>
      <view class="bridge"></view>
      <view class="bar tall"></view>
      <view class="dot"></view>
    </view>
  </view>

  <view class="card todo-card">
    <view class="section-title">
      <text>当前待办</text>
    </view>
    <view class="todo-row" wx:for="{{todos}}" wx:key="title">
      <view class="priority-dot {{item.level}}"></view>
      <view class="todo-main">
        <view class="todo-title">{{item.title}}</view>
        <view class="muted">{{item.desc}}</view>
      </view>
      <view class="todo-time">{{item.time}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">
      <text>服务功能</text>
    </view>
    <view class="feature-grid">
      <view class="feature pressable" wx:for="{{features}}" wx:key="title" bindtap="openFeature" data-path="{{item.path}}">
        <view class="feature-icon {{item.color}}">{{item.icon}}</view>
        <view class="feature-title">{{item.title}}</view>
      </view>
    </view>
  </view>

  <view class="overview-grid">
    <view class="mini-card pressable" wx:for="{{stats}}" wx:key="label">
      <view class="stat-value">{{item.value}}</view>
      <view class="muted">{{item.label}}</view>
    </view>
  </view>
</view>
