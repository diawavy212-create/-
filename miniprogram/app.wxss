page {
  background: #efeeee;
  color: #09213a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 0 28rpx 36rpx;
  box-sizing: border-box;
}

.top-red {
  margin: 0 -28rpx;
  padding: 36rpx 36rpx 28rpx;
  color: #ffffff;
  background: #c51624;
}

.nav-title {
  text-align: center;
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 800;
}

.card {
  margin: 24rpx 0;
  padding: 28rpx;
  background: #f6f6f6;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(90, 60, 60, 0.08);
  box-sizing: border-box;
}

.section-title {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-left: 18rpx;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  width: 6rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #c51624;
}

.muted {
  color: #697789;
  font-size: 24rpx;
  line-height: 36rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 16rpx;
  color: #c51624;
  background: #f9e6e8;
  border-radius: 18rpx;
  font-size: 20rpx;
}

.primary-button {
  height: 84rpx;
  line-height: 84rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #c51624, #d83a45);
  border-radius: 16rpx;
  font-weight: 700;
}

.pressable {
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.pressable:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.empty {
  padding: 80rpx 28rpx;
  text-align: center;
  color: #7b8794;
}

.empty-icon {
  margin-bottom: 16rpx;
  font-size: 60rpx;
}
