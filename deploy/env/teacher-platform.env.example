# Copy to /etc/teacher-platform/teacher-platform.env and fill production values.

HTTP_ADDR=127.0.0.1:8090
MYSQL_DSN=teacher_platform_user:REPLACE_PASSWORD@tcp(127.0.0.1:3306)/teacher_platform?charset=utf8mb4&parseTime=True&loc=Local

CAS_ENDPOINT=https://cas.example.edu
CAS_SERVICE_URL=https://teacher.example.edu
WECHAT_APP_ID=REPLACE_WECHAT_APP_ID
WECHAT_APP_SECRET=REPLACE_WECHAT_APP_SECRET

ADMIN_TOKEN_AUDIENCE=teacher-platform-admin
AUTH_TOKEN_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARS
ADMIN_LOGIN_PASSWORD=REPLACE_WITH_ADMIN_LOGIN_PASSWORD
DEV_AUTH_ENABLED=false

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
MESSAGE_GATEWAY_URL=https://message.example.edu
